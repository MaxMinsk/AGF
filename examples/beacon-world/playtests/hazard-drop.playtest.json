{
  "$schema": "https://agentsgameframework.dev/schemas/playtest.schema.json",
  "id": "hazard-drop",
  "name": "Drone loses its carried core when it walks into the hazard pulse",
  "project": "beacon-world",
  "description": "Pickup core.north, then teleport into hazard.center. The hazard's pulse drops the carried core (Carrier.carrying clears, the core is parked as consumed) regardless of where in the cycle the radius currently is, because the drone stands at the hazard's centre.",
  "steps": [
    {
      "kind": "applyCommands",
      "commands": [
        {
          "kind": "component.set",
          "entityId": "player.drone",
          "component": "Transform",
          "data": { "position": [-1.5, 0.4, -2.5], "rotation": [0, 0, 0], "scale": [0.7, 0.7, 0.7] }
        }
      ]
    },
    { "kind": "wait", "seconds": 0.15 },
    {
      "kind": "expectComponent",
      "entityId": "player.drone",
      "component": "Carrier",
      "match": { "carrying": "core.north" }
    },
    {
      "kind": "applyCommands",
      "commands": [
        {
          "kind": "component.set",
          "entityId": "player.drone",
          "component": "Transform",
          "data": { "position": [-1.6, 0.4, -0.6], "rotation": [0, 0, 0], "scale": [0.7, 0.7, 0.7] }
        }
      ]
    },
    { "kind": "wait", "seconds": 0.2 },
    {
      "kind": "expectComponent",
      "entityId": "core.north",
      "component": "Pickup",
      "match": { "consumed": true }
    }
  ]
}
