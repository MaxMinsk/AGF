{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentsgameframework.dev/examples/beacon-world/schemas/scene-extensions.schema.json",
  "title": "Beacon World Scene Extensions",
  "description": "Project-local component types that extend the base scene schema for Beacon World only. The engine recognises this file because it sits at <projectDir>/schemas/scene-extensions.schema.json.",
  "components": {
    "Pickup": {
      "$ref": "#/definitions/pickupComponent"
    },
    "Carrier": {
      "$ref": "#/definitions/carrierComponent"
    },
    "Repairable": {
      "$ref": "#/definitions/repairableComponent"
    },
    "Hazard": {
      "$ref": "#/definitions/hazardComponent"
    },
    "Health": {
      "$ref": "#/definitions/healthComponent"
    },
    "Invulnerable": {
      "$ref": "#/definitions/invulnerableComponent"
    },
    "Respawnable": {
      "$ref": "#/definitions/respawnableComponent"
    }
  },
  "definitions": {
    "pickupComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "originalPosition": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3,
          "description": "World position the pickup respawns at, if respawnAfter is set."
        },
        "respawnAfter": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Seconds the pickup stays consumed after deposit before respawning at originalPosition."
        },
        "consumed": {
          "type": "boolean",
          "description": "Runtime flag — true while the pickup is hidden waiting to respawn."
        },
        "respawnIn": {
          "type": "number",
          "minimum": 0,
          "description": "Runtime countdown towards respawn, seconds."
        }
      }
    },
    "carrierComponent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "carrying": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "repairableComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["accepts"],
      "properties": {
        "accepts": {
          "type": "string",
          "minLength": 1
        },
        "repaired": {
          "type": "boolean"
        },
        "repairedColor": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$",
          "description": "Legacy fallback colour used if repairedMaterial is omitted."
        },
        "repairedMaterial": {
          "type": "string",
          "minLength": 1,
          "description": "Material ref to swap to when the beacon is repaired. Decay restores the original material ref."
        },
        "originalColor": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$",
          "description": "Runtime field — colour stashed at repair time so decay can restore it when no original material was set."
        },
        "decayAfter": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Seconds the beacon stays repaired before decaying back."
        },
        "decayIn": {
          "type": "number",
          "minimum": 0,
          "description": "Runtime countdown towards decay, seconds."
        },
        "originalMaterial": {
          "type": "string",
          "minLength": 1,
          "description": "Runtime field — material ref stashed at repair time so decay can restore it."
        }
      }
    },
    "hazardComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minRadius", "maxRadius", "period"],
      "properties": {
        "minRadius": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Smallest danger radius reached during the pulse cycle, world units (XZ plane)."
        },
        "maxRadius": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Largest danger radius reached during the pulse cycle, world units (XZ plane)."
        },
        "period": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Full pulse cycle length in seconds."
        },
        "damage": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "How much health a carrier loses per hit. Defaults to 1."
        },
        "invulnerabilitySeconds": {
          "type": "number",
          "minimum": 0,
          "description": "After a hit the carrier gets this many seconds of immunity. Defaults to 1."
        }
      }
    },
    "healthComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current", "max"],
      "properties": {
        "current": {
          "type": "number",
          "minimum": 0
        },
        "max": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "invulnerableComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["until"],
      "properties": {
        "until": {
          "type": "number",
          "minimum": 0,
          "description": "Time-elapsed value past which the entity becomes vulnerable again."
        }
      }
    },
    "respawnableComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["position"],
      "properties": {
        "position": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3,
          "description": "World position the entity is sent back to when it dies and respawns."
        }
      }
    }
  }
}
