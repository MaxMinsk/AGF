{
  "agfFormatVersion": 1,
  "id": "shadows-bench",
  "name": "Shadows Bench",
  "startScene": "scenes/start.scene.json",
  "assetRoot": "assets",
  "render": {
    "mode": "webgpu",
    "background": "#5d7d9b",
    "skyGradient": {
      "top": "#3f6589",
      "bottom": "#bdc8d2"
    },
    "color": {
      "toneMapping": "aces-filmic",
      "exposure": 0.9
    },
    "batching": {
      "auto": true
    },
    "shadows": {
      "algorithm": "pcss",
      "csm": {
        "enabled": true,
        "cascades": 3,
        "maxFar": 120,
        "mode": "practical",
        "shadowMapSize": 1024,
        "shadowBias": -0.000005,
        "shadowNormalBias": 0.06,
        "lightDirection": [
          -0.45,
          -1,
          -0.35
        ],
        "lightIntensity": 2.1
      }
    }
  },
  "profiles": [
    "static"
  ]
}
