{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentsgameframework.dev/schemas/project.schema.json",
  "title": "AGF Project Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "startScene", "assetRoot", "render", "profiles"],
  "properties": {
    "agfFormatVersion": {
      "type": "integer",
      "minimum": 1,
      "description": "AGF project format version. Bumped on breaking schema changes; absence is treated as version 1 with a deprecation warning."
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "startScene": {
      "type": "string",
      "minLength": 1
    },
    "assetRoot": {
      "type": "string",
      "minLength": 1
    },
    "render": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {
          "enum": ["webgl"]
        },
        "background": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$"
        }
      }
    },
    "profiles": {
      "type": "array",
      "items": {
        "enum": ["static", "connected", "authoritative"]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "physics": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional Rapier3D physics config (M24). When `enabled: true`, the runtime lazy-imports the Rapier WASM adapter and registers PhysicsSyncSystem in the fixed-update loop. Projects that omit this block pay zero bundle cost.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Master toggle. False (or absent) → no Rapier import, no PhysicsSyncSystem."
        },
        "gravity": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3,
          "default": [0, -9.81, 0],
          "description": "World gravity vector in m/s²."
        },
        "fixedDt": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 0.01666666666,
          "description": "Physics step in seconds. Defaults to 1/60 — matches the engine's fixed-update tick. Override to slow-mo (0.0083 = 120 Hz) or potato mode (0.033 = 30 Hz)."
        }
      }
    },
    "persistence": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional persistence allowlist. When present, runtime.save() persists only the component values listed here. Absent → save/load throw at runtime.",
      "required": ["components"],
      "properties": {
        "components": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "slot": {
          "type": "string",
          "minLength": 1,
          "description": "Default save slot. Defaults to 'default'."
        }
      }
    }
  }
}
