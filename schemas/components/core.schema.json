{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentsgameframework.dev/schemas/components/core.schema.json",
  "title": "AGF Core components",
  "description": "Component definitions for the core domain. Pulled in by scene.schema.json via $ref; inlined into the bundled schema by engine/tools/schemas/load-scene-schema.ts.",
  "type": "object",
  "definitions": {
    "nameComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "transformComponent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "position": {
          "$ref": "common.schema.json#/definitions/vec3"
        },
        "rotation": {
          "$ref": "common.schema.json#/definitions/vec3"
        },
        "scale": {
          "$ref": "common.schema.json#/definitions/vec3"
        },
        "parent": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-._]*$",
          "description": "Optional entity id of this transform's parent. When set, position/rotation/scale are interpreted in the parent's local frame; otherwise they are world-frame. Cycle / self-reference / missing-target are validated by engine check."
        }
      }
    },
    "spinComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "axis",
        "speed"
      ],
      "properties": {
        "axis": {
          "enum": [
            "x",
            "y",
            "z"
          ]
        },
        "speed": {
          "type": "number"
        }
      }
    },
    "playerControlledComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "speed"
      ],
      "properties": {
        "speed": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    }
  }
}
