{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentsgameframework.dev/schemas/scene.schema.json",
  "title": "AGF Scene",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "entities"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "entities": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/entity"
      }
    },
    "instances": {
      "type": "array",
      "description": "Optional prefab instances. Each entry expands into a regular entity at scene-load time. The engine validates these against the prefab registry; missing prefabs surface as AGF_SCENE_INSTANCE_PREFAB_MISSING.",
      "items": { "$ref": "#/definitions/instance" }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "description": "Image-based-lighting environment (M21-env-generated). When absent, the renderer applies the `generated` RoomEnvironment fallback so MeshStandardMaterial / MeshPhysicalMaterial render with believable PBR out of the box. Set `kind: \"none\"` to opt out (e.g. for a fully unlit project).",
      "properties": {
        "kind": {
          "enum": ["generated", "none"],
          "default": "generated"
        }
      }
    }
  },
  "definitions": {
    "instance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "prefab"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-._]*$",
          "description": "Entity id after expansion; must be unique in the scene."
        },
        "prefab": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Id of a prefab declared in this project's prefabs/ directory."
        },
        "overrides": {
          "type": "object",
          "description": "Component overrides merged on top of the prefab's components at expansion time. Keys are component names."
        }
      }
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "components"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-._]*$"
        },
        "components": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "Name": {
              "$ref": "#/definitions/nameComponent"
            },
            "Transform": {
              "$ref": "#/definitions/transformComponent"
            },
            "Camera": {
              "$ref": "#/definitions/cameraComponent"
            },
            "MeshRenderer": {
              "$ref": "#/definitions/meshRendererComponent"
            },
            "Spin": {
              "$ref": "#/definitions/spinComponent"
            },
            "PlayerControlled": {
              "$ref": "#/definitions/playerControlledComponent"
            },
            "Networked": {
              "$ref": "#/definitions/networkedComponent"
            },
            "Presence": {
              "$ref": "#/definitions/presenceComponent"
            },
            "Light": {
              "$ref": "#/definitions/lightComponent"
            },
            "ShadowFlags": {
              "$ref": "#/definitions/shadowFlagsComponent"
            },
            "Batchable": {
              "$ref": "#/definitions/batchableComponent"
            }
          }
        }
      }
    },
    "nameComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "transformComponent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "position": {
          "$ref": "#/definitions/vec3"
        },
        "rotation": {
          "$ref": "#/definitions/vec3"
        },
        "scale": {
          "$ref": "#/definitions/vec3"
        },
        "parent": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-._]*$",
          "description": "Optional entity id of this transform's parent. When set, position/rotation/scale are interpreted in the parent's local frame; otherwise they are world-frame. Cycle / self-reference / missing-target are validated by engine check."
        }
      }
    },
    "cameraComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "enum": ["perspective", "orthographic"]
        },
        "active": {
          "type": "boolean"
        },
        "fov": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "near": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "far": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "meshRendererComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mesh"],
      "properties": {
        "mesh": {
          "anyOf": [
            {
              "enum": ["box", "sphere", "plane"]
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "material": {
          "type": "string",
          "minLength": 1
        },
        "color": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$"
        }
      }
    },
    "vec3": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "minItems": 3,
      "maxItems": 3
    },
    "spinComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["axis", "speed"],
      "properties": {
        "axis": {
          "enum": ["x", "y", "z"]
        },
        "speed": {
          "type": "number"
        }
      }
    },
    "playerControlledComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["speed"],
      "properties": {
        "speed": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "networkedComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authority"],
      "properties": {
        "authority": {
          "enum": ["server", "client"]
        },
        "channel": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "presenceComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["playerId"],
      "properties": {
        "playerId": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$",
          "minLength": 1,
          "maxLength": 64
        }
      }
    },
    "lightComponent": {
      "description": "Light source (M21-light-schema). Polymorphic on `kind`. Position + rotation come from the entity's Transform — `LightSyncSystem` pushes the resolved world transform onto the underlying Three.js light. `castShadow` enables shadow-map rendering for that light (gated by the renderer's shadow pipeline, see M21-shadow-basic).",
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": {
          "enum": ["directional", "point", "spot", "ambient", "hemisphere", "rect-area"]
        },
        "color": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$",
          "default": "#ffffff"
        },
        "intensity": {
          "type": "number",
          "minimum": 0,
          "default": 1
        },
        "castShadow": {
          "type": "boolean",
          "default": false
        },
        "shadow": {
          "type": "object",
          "additionalProperties": false,
          "description": "Per-light shadow-map config; ignored unless castShadow is true.",
          "properties": {
            "mapSize": {
              "type": "integer",
              "enum": [256, 512, 1024, 2048, 4096],
              "default": 1024
            },
            "bias": { "type": "number" },
            "normalBias": { "type": "number" },
            "radius": { "type": "number", "minimum": 0 },
            "camera": {
              "type": "object",
              "additionalProperties": false,
              "description": "Orthographic shadow camera frustum (directional lights) or near/far cutoffs (spot/point).",
              "properties": {
                "left": { "type": "number" },
                "right": { "type": "number" },
                "top": { "type": "number" },
                "bottom": { "type": "number" },
                "near": { "type": "number", "exclusiveMinimum": 0 },
                "far": { "type": "number", "exclusiveMinimum": 0 }
              }
            }
          }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "point" } }, "required": ["kind"] },
          "then": {
            "properties": {
              "distance": { "type": "number", "minimum": 0, "default": 0, "description": "Cutoff distance; 0 = no cutoff (physical 1/r² falloff)." },
              "decay": { "type": "number", "minimum": 0, "default": 2 }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "spot" } }, "required": ["kind"] },
          "then": {
            "properties": {
              "distance": { "type": "number", "minimum": 0, "default": 0 },
              "decay": { "type": "number", "minimum": 0, "default": 2 },
              "angle": { "type": "number", "exclusiveMinimum": 0, "maximum": 1.5707963267948966, "description": "Cone half-angle in radians; max π/2." },
              "penumbra": { "type": "number", "minimum": 0, "maximum": 1, "default": 0 },
              "target": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9-._]*$",
                "description": "Optional entity id whose world position the spot points at. Defaults to scene origin."
              }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "directional" } }, "required": ["kind"] },
          "then": {
            "properties": {
              "target": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9-._]*$",
                "description": "Optional entity id whose world position the directional light points at. Defaults to scene origin."
              }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "hemisphere" } }, "required": ["kind"] },
          "then": {
            "properties": {
              "groundColor": {
                "type": "string",
                "pattern": "^#[0-9a-fA-F]{6}$",
                "default": "#000000"
              }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "rect-area" } }, "required": ["kind"] },
          "then": {
            "properties": {
              "width": { "type": "number", "exclusiveMinimum": 0, "default": 1 },
              "height": { "type": "number", "exclusiveMinimum": 0, "default": 1 }
            }
          }
        }
      ]
    },
    "shadowFlagsComponent": {
      "description": "Per-mesh shadow opt-out (M21-shadow-basic). When absent, default is { cast: true, receive: true } — matching Unity's defaults. Set either to false as a perf escape hatch.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cast": { "type": "boolean", "default": true },
        "receive": { "type": "boolean", "default": true }
      }
    },
    "batchableComponent": {
      "description": "Opts an entity into the M17 renderer batcher. BatchingSystem groups entities by (mesh + material + shadow flags + group) and emits one Three.js InstancedMesh per bucket. The `group` field is an authoring hint — siblings sharing the same group prefer the same bucket. The renderer treats entities WITHOUT this component as un-batched (single Mesh per entity). Omit to keep the existing per-entity path.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "group": {
          "type": "string",
          "minLength": 1,
          "description": "Optional authoring hint. Entities with the same group + matching mesh/material/shadow keys share an InstancedMesh bucket."
        }
      }
    }
  }
}
