{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentsgameframework.dev/schemas/scene.schema.json",
  "title": "AGF Scene",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "entities"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "entities": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/entity"
      }
    },
    "instances": {
      "type": "array",
      "description": "Optional prefab instances. Each entry expands into a regular entity at scene-load time. The engine validates these against the prefab registry; missing prefabs surface as AGF_SCENE_INSTANCE_PREFAB_MISSING.",
      "items": { "$ref": "#/definitions/instance" }
    }
  },
  "definitions": {
    "instance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "prefab"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-._]*$",
          "description": "Entity id after expansion; must be unique in the scene."
        },
        "prefab": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Id of a prefab declared in this project's prefabs/ directory."
        },
        "overrides": {
          "type": "object",
          "description": "Component overrides merged on top of the prefab's components at expansion time. Keys are component names."
        }
      }
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "components"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-._]*$"
        },
        "components": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "Name": {
              "$ref": "#/definitions/nameComponent"
            },
            "Transform": {
              "$ref": "#/definitions/transformComponent"
            },
            "Camera": {
              "$ref": "#/definitions/cameraComponent"
            },
            "MeshRenderer": {
              "$ref": "#/definitions/meshRendererComponent"
            },
            "Spin": {
              "$ref": "#/definitions/spinComponent"
            },
            "PlayerControlled": {
              "$ref": "#/definitions/playerControlledComponent"
            },
            "Networked": {
              "$ref": "#/definitions/networkedComponent"
            },
            "Presence": {
              "$ref": "#/definitions/presenceComponent"
            }
          }
        }
      }
    },
    "nameComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "transformComponent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "position": {
          "$ref": "#/definitions/vec3"
        },
        "rotation": {
          "$ref": "#/definitions/vec3"
        },
        "scale": {
          "$ref": "#/definitions/vec3"
        },
        "parent": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-._]*$",
          "description": "Optional entity id of this transform's parent. When set, position/rotation/scale are interpreted in the parent's local frame; otherwise they are world-frame. Cycle / self-reference / missing-target are validated by engine check."
        }
      }
    },
    "cameraComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "enum": ["perspective", "orthographic"]
        },
        "active": {
          "type": "boolean"
        },
        "fov": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "near": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "far": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "meshRendererComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mesh"],
      "properties": {
        "mesh": {
          "anyOf": [
            {
              "enum": ["box", "sphere", "plane"]
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "material": {
          "type": "string",
          "minLength": 1
        },
        "color": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$"
        }
      }
    },
    "vec3": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "minItems": 3,
      "maxItems": 3
    },
    "spinComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["axis", "speed"],
      "properties": {
        "axis": {
          "enum": ["x", "y", "z"]
        },
        "speed": {
          "type": "number"
        }
      }
    },
    "playerControlledComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["speed"],
      "properties": {
        "speed": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "networkedComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authority"],
      "properties": {
        "authority": {
          "enum": ["server", "client"]
        },
        "channel": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "presenceComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["playerId"],
      "properties": {
        "playerId": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$",
          "minLength": 1,
          "maxLength": 64
        }
      }
    }
  }
}
