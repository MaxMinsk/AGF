{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentsgameframework.dev/schemas/scene.schema.json",
  "title": "AGF Scene",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "entities"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "entities": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/entity"
      }
    },
    "instances": {
      "type": "array",
      "description": "Optional prefab instances. Each entry expands into a regular entity at scene-load time. The engine validates these against the prefab registry; missing prefabs surface as AGF_SCENE_INSTANCE_PREFAB_MISSING.",
      "items": {
        "$ref": "#/definitions/instance"
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "description": "Image-based-lighting environment. `generated` (default) applies Three's RoomEnvironment via PMREMGenerator. `none` opts out. `hdr` loads an equirectangular `.hdr` via RGBELoader. `cube` loads a 6-face cubemap via CubeTextureLoader — both HDR and cube go through PMREMGenerator so they supply IBL, not just a skybox.",
      "properties": {
        "kind": {
          "enum": [
            "generated",
            "none",
            "hdr",
            "cube"
          ],
          "default": "generated"
        },
        "url": {
          "type": "string",
          "minLength": 1,
          "description": "Path to an equirectangular `.hdr` file under the project's assets root. Required when `kind: \"hdr\"`."
        },
        "faces": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Six face URLs in three.js CubeTextureLoader order: [+x, -x, +y, -y, +z, -z]. Required when `kind: \"cube\"`."
        },
        "intensity": {
          "type": "number",
          "minimum": 0,
          "default": 1,
          "description": "Multiplier on the scene's environment intensity. Only meaningful for `kind: \"hdr\"` or `kind: \"cube\"`."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "hdr"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "required": [
              "url"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "cube"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "required": [
              "faces"
            ]
          }
        }
      ]
    }
  },
  "definitions": {
    "instance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "prefab"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-._]*$",
          "description": "Entity id after expansion; must be unique in the scene."
        },
        "prefab": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Id of a prefab declared in this project's prefabs/ directory."
        },
        "overrides": {
          "type": "object",
          "description": "Component overrides merged on top of the prefab's components at expansion time. Keys are component names."
        }
      }
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "components"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-._]*$"
        },
        "components": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "Name": {
              "$ref": "components/core.schema.json#/definitions/nameComponent"
            },
            "Transform": {
              "$ref": "components/core.schema.json#/definitions/transformComponent"
            },
            "Camera": {
              "$ref": "components/camera.schema.json#/definitions/cameraComponent"
            },
            "MeshRenderer": {
              "$ref": "components/render.schema.json#/definitions/meshRendererComponent"
            },
            "Spin": {
              "$ref": "components/core.schema.json#/definitions/spinComponent"
            },
            "PlayerControlled": {
              "$ref": "components/core.schema.json#/definitions/playerControlledComponent"
            },
            "Networked": {
              "$ref": "components/network.schema.json#/definitions/networkedComponent"
            },
            "Presence": {
              "$ref": "components/network.schema.json#/definitions/presenceComponent"
            },
            "Light": {
              "$ref": "components/render.schema.json#/definitions/lightComponent"
            },
            "ShadowFlags": {
              "$ref": "components/render.schema.json#/definitions/shadowFlagsComponent"
            },
            "Batchable": {
              "$ref": "components/render.schema.json#/definitions/batchableComponent"
            },
            "LOD": {
              "$ref": "components/render.schema.json#/definitions/lodComponent"
            },
            "RigidBody3D": {
              "$ref": "components/physics-3d.schema.json#/definitions/rigidBody3DComponent"
            },
            "Collider3D": {
              "$ref": "components/physics-3d.schema.json#/definitions/collider3DComponent"
            },
            "CharacterController3D": {
              "$ref": "components/physics-3d.schema.json#/definitions/characterController3DComponent"
            },
            "OrbitCamera": {
              "$ref": "components/camera.schema.json#/definitions/orbitCameraComponent"
            },
            "FollowCamera": {
              "$ref": "components/camera.schema.json#/definitions/followCameraComponent"
            },
            "Tweens": {
              "$ref": "components/gamefeel.schema.json#/definitions/tweensComponent"
            },
            "ParticleEmitter": {
              "$ref": "components/gamefeel.schema.json#/definitions/particleEmitterComponent"
            },
            "CinematicCamera": {
              "$ref": "components/camera.schema.json#/definitions/cinematicCameraComponent"
            },
            "WaypointMover": {
              "$ref": "components/gamefeel.schema.json#/definitions/waypointMoverComponent"
            }
          }
        }
      }
    }
  }
}
