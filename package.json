{
  "name": "agents-game-framework",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Agent-first browser game framework. TypeScript + Three.js + JSON schemas + ECS + CLI/dev-bridge tooling so AI coding agents can author, validate and playtest games without a visual editor.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaxMinsk/AGF.git"
  },
  "bugs": {
    "url": "https://github.com/MaxMinsk/AGF/issues"
  },
  "homepage": "https://github.com/MaxMinsk/AGF#readme",
  "keywords": [
    "game-engine",
    "game-framework",
    "browser-games",
    "threejs",
    "ecs",
    "agent-first",
    "ai-coding",
    "rapier",
    "json-schema",
    "typescript"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "engine:check": "tsx engine/tools/cli.ts check",
    "engine:check:examples": "node scripts/engine-check-examples.mjs",
    "engine:inspect": "tsx engine/tools/cli.ts inspect",
    "engine:summarize": "tsx engine/tools/cli.ts summarize",
    "engine:doctor": "tsx engine/tools/cli.ts doctor",
    "engine:migrate": "tsx engine/tools/cli.ts migrate",
    "engine:asset": "tsx engine/tools/cli.ts asset",
    "engine:replay": "tsx engine/tools/cli.ts replay",
    "engine:docs": "tsx engine/tools/cli.ts docs",
    "engine:patch": "tsx engine/tools/cli.ts patch",
    "backlog:check": "node scripts/backlog/check.mjs",
    "backlog:render": "node scripts/backlog/render.mjs",
    "engine:list": "tsx engine/tools/cli.ts list",
    "engine:explain": "tsx engine/tools/cli.ts explain",
    "engine:new": "tsx engine/tools/cli.ts new",
    "engine:screenshot": "tsx engine/tools/cli.ts screenshot",
    "bench:ecs": "tsx benchmarks/ecs/index.ts",
    "bench:ecs:alloc": "node --expose-gc --import tsx benchmarks/ecs/alloc.ts",
    "backend:node": "tsx examples/backends/node-world-server/src/index.ts",
    "backend:node:serve": "tsx examples/backends/node-world-server/src/index.ts --serve",
    "backend:dotnet": "dotnet run --project examples/backends/dotnet-world-server/GameServer.csproj",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --project=smoke",
    "test:e2e:preview": "playwright test --config=playwright.preview.config.ts",
    "test:e2e:full-dev": "playwright test --project=chromium --project=serial-heavy",
    "playtest:watch": "node scripts/watch-playtests.mjs",
    "bundle:check": "node scripts/check-bundle-size.mjs",
    "imports:check": "node scripts/check-import-boundaries.mjs",
    "systems:check": "node scripts/check-system-queries.mjs",
    "repo:hygiene": "node scripts/check-repo-hygiene.mjs",
    "preflight": "npm run repo:hygiene && npm run engine:check:examples && npm run imports:check && npm run systems:check && npm run typecheck && npm run test && npm run build && npm run bundle:check && npm run test:e2e:smoke"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/extensions": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.7.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6",
    "ws": "^8.20.1"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "@three.ez/batched-mesh-extensions": "^0.0.11",
    "@types/three": "^0.184.1",
    "ajv": "^8.20.0",
    "three": "^0.184.0"
  }
}
